# VendorGuard AI - Environment variables
# Copy this file to .env and fill in the values you have.
# Every key is OPTIONAL. If a key is missing, the app runs in MOCK / local-fallback
# mode for that integration and still returns realistic demo data.

# --- OSINT sources ---
SHODAN_API_KEY=
HIBP_API_KEY=
VIRUSTOTAL_API_KEY=

# --- AI (pick ONE provider; every missing key silently falls back to template) ---
AI_PROVIDER=openai      # anthropic | openai | openrouter | mock

# Anthropic (best tone for Indian DPDP context)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenAI (or any OpenAI-compatible gateway — set OPENAI_BASE_URL to switch)
OPENAI_API_KEY=
OPENAI_BASE_URL=        # e.g. https://api.groq.com/openai/v1   (leave blank for api.openai.com)
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (one key → 200+ models. Cheapest path to Claude via OpenAI SDK.)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- WhatsApp alerts (Twilio sandbox works with a free number) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# --- Nuclei (optional; install via `go install` — falls back to mock templates if absent) ---
NUCLEI_BIN=nuclei
NUCLEI_TEMPLATE_TAGS=cve,exposure,misconfig

# --- RAG (optional; falls back to local TF-IDF retriever if unset) ---
DPDP_ACT_PDF_PATH=

# --- App ---
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
DEMO_MODE=true           # true = blend deterministic demo data; false = live APIs only
SQLITE_PATH=./vendorguard.db
